FROM python:3.11-slim
RUN apt-get update && apt-get install -y gcc libffi-dev libssl-dev git && rm -rf /var/lib/apt/lists/*
WORKDIR /app
# E.1: hash-pinned install from the lockfile generated by
# scripts/refresh-deps.sh. The .txt is the human-edited input; .lock is the
# fully-resolved hash-locked artifact.
COPY requirements.lock .
RUN pip install --no-cache-dir --require-hashes -r requirements.lock
COPY *.py .
# SC.3: ship the hash-pinned ESPHome constraints files alongside the
# source. version_manager._install() reads from esphome-constraints/
# at runtime; without this COPY the auto-update path wouldn't see
# them (auto-update only rewrites .py files, not arbitrary data).
COPY esphome-constraints ./esphome-constraints
# IMAGE_VERSION is intentionally SEPARATE from CLIENT_VERSION (the source code
# version). Workers auto-update their source code from the server in place via
# os.execv, but the Docker image itself (system packages, Python, requirements)
# can't change that way. When the image changes, this number should be bumped
# so the server can detect workers running a stale image and prompt a rebuild.
COPY IMAGE_VERSION .
VOLUME /esphome-versions
# Store PlatformIO toolchains inside the persistent esphome-versions volume
# so they survive container recreations (avoid re-downloading toolchains each time).
ENV PLATFORMIO_CORE_DIR=/esphome-versions/platformio
ENTRYPOINT ["python", "client.py"]
