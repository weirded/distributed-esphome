#!/usr/bin/env bash
# Pre-push hook — runs the same checks as GitHub CI.
# Install with: bash scripts/install-hooks.sh
set -euo pipefail

echo "==> pre-push: running unit tests..."
pytest tests/ --ignore=tests/test_e2e_client.py -q

echo "==> pre-push: mypy — server..."
mypy ha-addon/server/ --ignore-missing-imports

echo "==> pre-push: mypy — client..."
mypy ha-addon/client/ --ignore-missing-imports

echo "==> pre-push: checking changelog has entry for current version..."
VERSION="$(cat ha-addon/VERSION)"
if ! grep -q "^## ${VERSION}\$" ha-addon/CHANGELOG.md; then
  echo "ERROR: ha-addon/CHANGELOG.md has no entry for version ${VERSION}"
  echo "Add a '## ${VERSION}' section before pushing."
  exit 1
fi

echo "==> pre-push: all checks passed."
